# Base URL of the kredoc-daily-update Cloudflare Worker (no trailing slash).
# Not a secret — this is just where the client sends its Bearer-token
# requests. See worker/README.md for deploying the Worker itself; its real
# secrets (FAMILY_ACCESS_TOKEN, GEMINI_API_KEY) live only as Worker secrets,
# never in this file or any VITE_-prefixed variable.
VITE_WORKER_URL=https://kredoc-daily-update.your-subdomain.workers.dev
