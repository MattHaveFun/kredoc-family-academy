# Twelve Data API key (free tier: 800 requests/day, 8/minute) — https://twelvedata.com
# For deployed builds, set this as a GitHub Actions repository secret named
# TWELVEDATA_API_KEY; the deploy workflow injects it at build time.
VITE_TWELVEDATA_API_KEY=your_api_key_here

# Optional: OpenAI API key for the "What it actually means" daily narrative.
# NOTE: any VITE_-prefixed variable is bundled into the client JS and visible
# to anyone who inspects the site. Only use a restricted, low-spend-limit key.
VITE_OPENAI_API_KEY=
